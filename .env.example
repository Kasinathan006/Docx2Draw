# Doc2Draw AI — docker-compose environment.
# Copy to `.env`. Everything is OPTIONAL: with no values set, the stack runs
# with in-process/Redis jobs, local storage, anonymous access, and no billing.

# --- Supabase (optional: auth + storage + db) ---
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_JWT_SECRET=
DATABASE_URL=

# --- Stripe (optional: billing) ---
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
