# Doc2Draw backend configuration.
# Copy to `.env` and fill in only what you need — everything is optional.
# With NO values set, the API runs fully locally (in-process jobs, local storage,
# anonymous access, no billing).

# --- CORS ---
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# --- Uploads ---
MAX_UPLOAD_MB=512

# --- Background worker (optional) ---
# Set REDIS_URL to run jobs on Celery instead of in-process threads.
# REDIS_URL=redis://localhost:6379/0
WORKERS=2

# --- Supabase (optional: auth + storage + db) ---
# SUPABASE_URL=https://xxxx.supabase.co
# SUPABASE_ANON_KEY=
# SUPABASE_SERVICE_ROLE_KEY=
# SUPABASE_JWT_SECRET=          # enables JWT auth when set
# DATABASE_URL=postgresql+psycopg://user:pass@host:5432/postgres

# --- Stripe (optional: billing webhooks) ---
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# STRIPE_PRICE_PRO=price_...
# STRIPE_PRICE_TEAM=price_...

# --- Cloud object storage (optional: S3 / R2) ---
# S3_BUCKET=
# S3_REGION=
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=

# --- LLM extraction (optional; falls back to rule-based) ---
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
# GEMINI_API_KEY=
